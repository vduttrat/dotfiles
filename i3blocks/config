[wifi]
command=$HOME/.config/i3blocks/scripts/wifi
markup=pango
interval=1

[date]
command=$HOME/.config/i3blocks/scripts/date
markup=pango
interval=once

[time]
command=$HOME/.config/i3blocks/scripts/time
markup=pango
interval=30

[volume]
command=$HOME/.config/i3blocks/scripts/volume
markup=pango
interval=1

[battery]
command=$HOME/.config/i3blocks/scripts/battery
markup=pango
interval=60

[logo]
command=$HOME/.config/i3blocks/scripts/logo
markup=pango
interval=once

